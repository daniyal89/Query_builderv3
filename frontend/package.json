{
  "name": "duckdb-data-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node ./scripts/write-build-report.mjs",
    "build:report": "node ./scripts/write-build-report.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "lint": "eslint .",
    "test:coverage": "vitest run --coverage",
    "test:junit": "vitest run --reporter=default --reporter=junit --outputFile=frontend-test-results.xml"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.5.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "msw": "^1.3.5",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.46.1",
    "vite": "^5.4.0",
    "vitest": "^2.1.8"
  }
}
