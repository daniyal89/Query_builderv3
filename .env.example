# FastAPI app profile
DASHBOARD_ENV_PROFILE=dev
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8741
DASHBOARD_DEBUG=false

# Writable runtime state
# In local dev this can stay relative to the repo. For packaged desktop builds,
# prefer an absolute writable path next to the executable or under the user's
# app-data folder if your installer provisions one.
DASHBOARD_RUNTIME_DIR=./runtime
DASHBOARD_JOB_STORE_PATH=./runtime/job_store.sqlite3
DASHBOARD_JOB_RECOVER_INTERRUPTED=true

# Optional outbound proxy for environments that require manual proxy routing
# Use either DASHBOARD_* or standard env vars; backend now honors both forms.
# DASHBOARD_HTTP_PROXY=http://user:pass@proxy-host:port
# DASHBOARD_HTTPS_PROXY=http://user:pass@proxy-host:port
# DASHBOARD_NO_PROXY=127.0.0.1,localhost
# HTTP_PROXY=http://user:pass@proxy-host:port
# HTTPS_PROXY=http://user:pass@proxy-host:port
# NO_PROXY=127.0.0.1,localhost

# Optional split proxy host/port format (alternative to full URL form above)
# DASHBOARD_PROXY_HOST=10.96.5.20
# DASHBOARD_PROXY_PORT=80
# DASHBOARD_PROXY_USER=your_username
# DASHBOARD_PROXY_PASS=your_password

# Optional alternate Google API base URL if www.googleapis.com is blocked in your network
# DASHBOARD_GOOGLE_API_BASE_URL=https://content.googleapis.com/

# Optional emergency fallback (disabled by default)
# DASHBOARD_ENABLE_EMERGENCY_PROXY=false
# DASHBOARD_EMERGENCY_PROXY_HOST=10.96.5.20
# DASHBOARD_EMERGENCY_PROXY_PORT=80
