# FastAPI app profile
DASHBOARD_ENV_PROFILE=dev
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8741
DASHBOARD_DEBUG=false

# Writable runtime state
# In local dev this can stay relative to the repo. For packaged desktop builds,
# prefer an absolute writable path next to the executable or under the user's
# app-data folder if your installer provisions one.
DASHBOARD_RUNTIME_DIR=./runtime
DASHBOARD_JOB_STORE_PATH=./runtime/job_store.sqlite3
DASHBOARD_JOB_RECOVER_INTERRUPTED=true
